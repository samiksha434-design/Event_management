# API Gateway URL - The central entry point for all backend services
# For local development, use the API Gateway port (default: 8000)
# For production, use your deployed API Gateway URL
VITE_API_URL=http://localhost:8000

# Optional: Override individual service URLs (not recommended - use API Gateway instead)
# VITE_AUTH_URL=http://localhost:8001
# VITE_EVENT_URL=http://localhost:8002
# VITE_ANNOUNCEMENT_URL=http://localhost:8003
# VITE_LEADERBOARD_URL=http://localhost:8004
# VITE_SETTINGS_URL=http://localhost:8005
